{
  "version": 2,
  "functions": {
    "api/index.js": {
      "memory": 1769,
      "maxDuration": 60,
      "includeFiles": "node_modules/@sparticuz/chromium/bin/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "crons": [
    {
      "path": "/radar/run",
      "schedule": "0 6 * * *"
    }
  ]
}